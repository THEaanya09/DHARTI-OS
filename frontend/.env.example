# Copy to frontend/.env.local and fill in your keys.
# Never commit .env.local — it is gitignored.

# Supabase (auth + profiles)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server-side only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Country State City API (onboarding location picker)
COUNTRY_STATE_CITY_API_KEY=your_country_state_city_api_key_here

# FastAPI backend (Next.js server-side proxy routes)
BACKEND_URL=http://127.0.0.1:8000
